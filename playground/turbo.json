{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "typecheck": {
      "cache": true,
      "dependsOn": ["^build", "codegen", "generate:mocks"]
    },
    "codegen": {
      "cache": true,
      "inputs": ["!src/mocks/**", "!src/api/**"],
      "outputs": ["src/api/**"]
    },
    "generate:mocks": {
      "cache": true,
      "inputs": ["!src/mocks/**", "!src/api/**"],
      "outputs": ["src/mocks/**"]
    }
  }
}
