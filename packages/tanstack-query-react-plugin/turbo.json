{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "codegen"]
    },
    "codegen": {
      "dependsOn": ["^build"],
      "outputs": [
        "src/ts-factory/service-operation.generated/**/*.ts"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "generate-ts-factory.mjs"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build", "codegen"]
    },
    "lint": {
      "dependsOn": ["^build", "codegen"]
    },
    "test": {
      "dependsOn": ["build"]
    }
  }
}
