{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "codegen"]
    },
    "codegen": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [
        "src/tests/fixtures/api/**/*.ts",
        "src/tests/fixtures/queryable-write-operations-api/**/*.ts",
        "src/tests/fixtures/files-api/**/*.ts"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build", "codegen"]
    },
    "lint": {
      "dependsOn": ["^build", "codegen"]
    },
    "test": {
      "dependsOn": ["build"]
    }
  }
}
