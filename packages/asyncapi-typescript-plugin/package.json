{
  "name": "@qraft/asyncapi-typescript-plugin",
  "version": "1.0.0-beta.6",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "yarn build --watch --noEmitOnError false",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 0",
    "clean": "rimraf dist/"
  },
  "publishConfig": {
    "access": "public"
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "dependencies": {
    "@qraft/asyncapi-plugin": "workspace:^",
    "@qraft/cli-utils": "workspace:*",
    "@qraft/plugin": "workspace:^",
    "@redocly/openapi-core": "^1.34.11",
    "ansi-colors": "^4.1.3",
    "commander": "^14.0.3",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@openapi-qraft/eslint-config": "workspace:*",
    "@qraft/test-utils": "workspace:*",
    "@types/node": "^22.19.17",
    "eslint": "^10.1.0",
    "memfs": "^4.57.1",
    "rimraf": "^6.1.3",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist",
    "src",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "!src/**/*.test.*",
    "!src/**/__snapshots__/**",
    "!src/**/*.spec.*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenAPI-Qraft/openapi-qraft.git",
    "directory": "packages/asyncapi-typescript-plugin"
  },
  "packageManager": "yarn@4.9.1"
}
