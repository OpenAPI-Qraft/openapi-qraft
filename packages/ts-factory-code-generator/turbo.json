{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "codegen": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "generate-factory-code-generator.mjs",
        "src/generateSourceFileFactoryCode.ts",
        "src/index.ts"
      ],
      "outputs": ["src/generateFactoryCode.ts"]
    },
    "build": {
      "dependsOn": ["codegen"]
    },
    "lint": {
      "dependsOn": ["codegen"]
    }
  }
}
