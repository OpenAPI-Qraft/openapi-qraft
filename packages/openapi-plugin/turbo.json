{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "write-package-version-file"]
    },
    "typecheck": {
      "dependsOn": ["^build", "write-package-version-file"]
    },
    "lint": {
      "dependsOn": ["^build", "write-package-version-file"]
    },
    "test": {
      "dependsOn": ["^build", "write-package-version-file"],
      "outputs": ["coverage/**"]
    }
  }
}
